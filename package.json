{
  "name": "@samyou/sshgit",
  "version": "0.1.0",
  "description": "CLI to manage multiple GitHub/GitLab SSH accounts on one machine.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "sshgit": "./dist/sshgit.js"
  },
  "files": [
    "dist/sshgit.js",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run index.ts",
    "typecheck": "bunx tsc --noEmit",
    "build": "rm -rf ./dist && bun build ./index.ts --target node --outfile ./dist/sshgit.js",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
